<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_expire_loyalty_points" model="ir.cron">
            <field name="name">Expire Loyalty Points</field>
            <field name="model_id" ref="model_loyalty_points_transaction"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_loyalty_points()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>

    <function model="ir.model.data" name="write">
        <function model="ir.model.data" name="search">
            <value eval="[('module', '=', 'customer_loyalty_points'), ('name', '=', 'action_expire_loyalty_points')]"/>
        </function>
        <value eval="{'noupdate': False}"/>
    </function>

    <!-- Server Action: Manual expiry of loyalty points -->
    <record id="action_expire_loyalty_points" model="ir.actions.server">
        <field name="name">Expire Loyalty Points</field>
        <field name="model_id" ref="model_loyalty_points_transaction"/>
        <field name="binding_model_id" ref="model_loyalty_points_transaction"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">model.action_expire_selected_loyalty_points()</field>
    </record>
</odoo>
