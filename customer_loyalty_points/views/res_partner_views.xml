<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form.loyalty.points</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_loyalty_transactions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-gift"
                        groups="sales_team.group_sale_salesman">
                    <field name="commercial_loyalty_points"
                           string="Loyalty Points"
                           widget="statinfo"/>
                </button>
            </div>
            <xpath expr="//notebook" position="inside">
                <page string="Loyalty Points" name="loyalty_points">
                    <group>
                        <field name="loyalty_points"
                               readonly="1"
                               invisible="id != commercial_partner_id"/>
                        <field name="commercial_loyalty_points"
                               readonly="1"
                               invisible="id == commercial_partner_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
